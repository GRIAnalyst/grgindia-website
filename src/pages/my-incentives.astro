---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Incentives" description="My Incentives - End-to-end incentive automation platform by GRG India.">
  <section class="bg-gradient-to-br from-green-600 to-green-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold">My Incentives</h1>
        <p class="mt-6 text-lg md:text-xl text-green-100">
          End-to-end incentive automation platform for managing complex channel incentive programs at scale.
        </p>
        <a
          href="/book-a-demo"
          class="mt-8 inline-block px-6 py-3 bg-white text-green-700 font-semibold rounded-lg hover:bg-green-50"
        >
          Request a Demo
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center">Key Features</h2>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: 'Incentive Engine', desc: 'Configure complex incentive rules with a no-code rule builder.' },
          { title: 'Automated Payouts', desc: 'Calculate and disburse incentives automatically with full audit trails.' },
          { title: 'Program Analytics', desc: 'Deep insights into program performance and partner behavior.' },
          { title: 'Scheme Management', desc: 'Design and manage multiple incentive schemes simultaneously.' },
          { title: 'Partner Portal', desc: 'Self-service portal for partners to track earnings and performance.' },
          { title: 'Integration Ready', desc: 'Seamless integration with ERP, CRM, and other enterprise systems.' },
        ].map((feature) => (
          <div class="p-6 border border-gray-200 rounded-xl">
            <h3 class="text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-gray-600">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Ordered by: buyer-intent + high engagement first, then proven traffic, then topical relevance
const MANUAL_ORDER = [
  // Tier 1: High engagement (40-130s) — readers who stay are your buyers
  '5-ideas-to-improve-the-sales-motivation-of-your-retail-employees',       // 92s engagement
  '5-motivational-emails-for-the-sales-team',                                // 49s engagement, 188 views
  'new-age-sales-incentive-programs-for-retail-4-0',                         // 49s engagement  (slug: eight-innovative-incentives-for-new-retail-4-0 if different)
  '10-ways-to-improve-your-rewards-recognition-program',                     // 42s engagement
  'how-to-create-a-sales-incentive-plan',                                    // 39s engagement
  'understanding-the-claims-process-in-channel-incentive-programs',          // 46s engagement
  'multiple-kpi-tracking-for-sales-teams',                                   // 52s engagement
  'sales-motivational-quotes-you-can-use',                                   // 83s engagement
  'personalized-and-data-driven-nudges-for-sales-reps',                      // 47s engagement
  '7-types-of-channel-incentive-programs',                                   // 48s engagement
  'features-to-look-for-before-finalizing-a-sales-incentive-solution',       // 40.5s engagement
  'why-excel-falls-short-for-managing-sales-incentives',                     // 28s engagement

  // Tier 2: Proven organic traffic drivers (on-brand)
  '5-best-channel-loyalty-software-program',                                 // 74 views
  'sales-incentives-everything-you-need-to-get-started',                     // 23 views
  'cosmetics-retail-the-shift-to-value-driven-incentives',                   // 19 views
  'what-beauty-personal-care-brands-miss-in-sales-incentives',               // 21 views

  // Tier 3: Industry-specific (supports solution pages)
  'designing-effective-incentive-programs-for-auto-dealerships',
  'designing-effective-incentive-programs-for-mechanics',
  'incentive-programs-for-auto-retailers',
  'auto-sector-incentives-a-guide-for-dealerships-retailers-and-mechanics',
  'how-to-make-your-mechanic-loyalty-program-work',
  'channel-loyalty-in-crop-care',
  'loyalty-seeds-industry-distributors-retailer',
  'drive-excellence-in-the-hospitality-sector-with-incentives',
  'product-visibility-apparel-brands-retailer-incentives',

  // Tier 4: Gamification & sales tools content
  'polls-revolutionize-your-sales-incentive',
  'boosting-sales-performance-with-personalized-nudges',
  'streamlining-incentive-claim-management',
  'personalized-certificates-for-sales-incentive-gamification',
  'boosting-sales-success-with-target-meters',
  'the-impact-of-leaderboards-on-sales-teams',
  'elevating-sales-success-with-fastest-finger-first-quizzes',
  'gamification-strategies-for-your-sales-incentives',
  'make-sales-incentives-more-exciting-with-gamification',

  // Tier 5: How-to guides and educational
  'how-to-track-sales-commission-effectively',
  'how-to-use-technology-to-manage-and-administer-a-sales-incentives-program',
  'how-to-launch-a-sales-incentives-program',
  'automated-incentive-calculation-benefits',
  'sales-incentive-software-solution',
  'watch-video-to-get-started-with-sales-incentives',
  'tips-for-measuring-the-effectiveness-of-a-sales-incentives-program',
  'why-data-is-the-secret-ingredient-to-effective-sales-incentive-programs',
  'engaging-channel-partner',
  'the-evolution-of-loyalty-programs-and-why-they-work',
  'what-can-motivate-retail-staff-in-retail-4-0',
  'eight-innovative-incentives-for-new-retail-4-0',

  // Tier 6: Seasonal & leadership
  'diwali-sales-how-to-incentivize-retailers-and-channel-partners',
  'how-to-create-winning-incentive-strategies-this-diwali-season',
  'female-leadership-shobhita-narain',
  'female-leadership-meenakshi-iyengar',
  'ceo-employee-engagement-5-mistakes-to-avoid',
  'hr-leaders-and-their-changing-priorities-in-2023',
  'are-you-an-effective-leader',
  '5-practical-ways-to-promote-work-life-balance-and-avoid-burnout',
];

const allPosts = await getCollection('blog');
const manualSet = new Set(MANUAL_ORDER);

// Build ordered list from manual array
const postMap = new Map(allPosts.map(p => [p.id, p]));
const orderedPosts = MANUAL_ORDER
  .map(slug => postMap.get(slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);

// Remainder: posts not in manual list, sorted by date descending
const remainderPosts = allPosts
  .filter(p => !manualSet.has(p.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = [...orderedPosts, ...remainderPosts];
const categories = ['All', 'Channel Partner Loyalty', 'Rewards & Recognition', 'Sales Incentives'];
---

<Layout title="Blog" description="Insights on channel incentives, loyalty programs, and employee engagement from GRG India.">
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Category Tabs -->
      <div class="flex flex-wrap justify-center gap-8 border-b border-gray-200 mb-10">
        {categories.map((cat) => (
          <button
            class="category-tab pb-2 text-sm font-medium transition-colors"
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Posts Grid -->
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="blog-card block border border-gray-100 rounded-lg overflow-hidden hover:shadow-md transition-shadow"
            data-category={post.data.category || ''}
          >
            {post.data.image ? (
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-[220px] object-cover"
              />
            ) : (
              <div class="w-full h-[220px] bg-gray-100" />
            )}
            <div class="px-3 py-4">
              <h2 class="text-sm font-medium text-gray-900 text-center leading-snug line-clamp-2">
                {post.data.title}
              </h2>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<script>
  const tabs = document.querySelectorAll('.category-tab');
  const cards = document.querySelectorAll('.blog-card');

  function setActiveTab(activeBtn: Element) {
    tabs.forEach((tab) => {
      tab.classList.remove('text-gray-900', 'border-b-2', 'border-gray-900');
      tab.classList.add('text-gray-400');
    });
    activeBtn.classList.remove('text-gray-400');
    activeBtn.classList.add('text-gray-900', 'border-b-2', 'border-gray-900');
  }

  function filterCards(category: string) {
    cards.forEach((card) => {
      if (category === 'All' || card.getAttribute('data-category') === category) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.getAttribute('data-filter') || 'All';
      setActiveTab(tab);
      filterCards(filter);
    });
  });

  // Set "All" as active on load
  const allTab = document.querySelector('.category-tab[data-filter="All"]');
  if (allTab) setActiveTab(allTab);
</script>

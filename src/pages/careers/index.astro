---
import Layout from '../../layouts/Layout.astro';

const openings = [
  {
    title: 'Digital Marketing Executive',
    slug: 'digital-marketing-executive',
    department: 'Marketing',
    location: 'Sewri West, Mumbai',
    type: 'Full-time',
    experience: '2+ years',
    summary: 'Own paid search, LinkedIn Ads, SEO, and conversion-rate optimization for our B2B SaaS product, My Incentives. Drive lead generation across digital channels.',
  },
  {
    title: 'Business Development Executive',
    slug: 'business-development-executive',
    department: 'Growth & Strategy',
    location: 'Mumbai, India',
    type: 'Full-time',
    experience: '1–2 years',
    summary: 'Drive new business opportunities in B2B SaaS sales for our incentive management platform, working with enterprise clients across India.',
  },
];

const testimonials = [
  {
    name: 'Pooja Chikula',
    title: 'Tech Lead',
    photo: '/images/careers/pooja.png',
    quote: 'I have been with this organization for over five years, and it has been a deeply great journey. The company has provided incredible opportunities for professional growth and continuous learning, ensuring I feel valued and motivated. The work-life balance is well supported.',
  },
  {
    name: 'Satya Prakash',
    title: 'Business Development Manager',
    photo: '/images/careers/satya.png',
    quote: 'Working at GRG India has been an incredible experience. The culture here truly encourages growth, collaboration, and innovation. Every day brings new opportunities to learn and contribute meaningfully. If you\'re looking for a workplace where your ideas matter and your efforts are valued, GRG India is the place to be.',
  },
  {
    name: 'Chetana Shelar',
    title: 'Senior UI/UX Designer',
    photo: '/images/careers/chetana.png',
    quote: 'Being part of GRG India has been a truly enriching experience. The environment here motivates you to think creatively, take ownership, and keep growing. I feel valued, supported, and inspired every single day. GRG India is a place where your passion turns into progress.',
  },
];

const jobPostingSchema = openings.map((job) => ({
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: job.title,
  description: job.summary,
  datePosted: '2026-03-01',
  employmentType: 'FULL_TIME',
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Mumbai',
      addressRegion: 'Maharashtra',
      addressCountry: 'IN',
    },
  },
  hiringOrganization: {
    '@type': 'Organization',
    name: 'GRG India',
    sameAs: 'https://www.grgindia.in',
    logo: 'https://www.grgindia.in/images/grg-india-logo.png',
  },
}));
---

<Layout
  title="Careers - Leaders In Incentives, Rewards & Loyalty Programs | GRG India"
  description="Careers at GRG India. Let's together make work enjoyable and fulfilling for people around the world."
  canonical="https://www.grgindia.in/careers/"
  ogImage="https://www.grgindia.in/images/careers/career-hero.png"
  jsonLd={jobPostingSchema[0]}
>

  <!-- Hero -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Left: text -->
        <div>
          <p class="text-sm font-semibold tracking-widest uppercase anim-fade-up" style="color: #E41E3A;">Careers at GRG India</p>
          <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight anim-fade-up" data-anim-delay="100" style="color: #0f1f3d;">
            Join us in making work enjoyable and fulfilling for all
          </h1>
          <p class="mt-5 text-lg text-gray-600 max-w-lg anim-fade-up" data-anim-delay="150">
            Help India's top brands transform how they reward performance — with technology that makes a real difference.
          </p>
          <a
            href="#openings"
            class="mt-8 inline-flex items-center gap-2 px-6 py-3 text-white font-semibold rounded-lg transition-colors anim-fade-up btn-brand-red"
            data-anim-delay="250"
          >
            See Open Roles
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <!-- Right: team photo -->
        <div>
          <img
            src="/images/careers/career-hero.png"
            alt="GRG India team"
            class="w-full rounded-2xl object-cover anim-slide-right"
            data-anim-delay="200"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Employee Testimonials -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((t, i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex flex-col justify-between anim-fade-up" data-anim-delay={i * 100}>
            <p class="text-gray-600 italic leading-relaxed mb-6">"{t.quote}"</p>
            <div class="flex items-center gap-3 mt-auto">
              <img src={t.photo} alt={t.name} class="w-12 h-12 rounded-full object-cover" />
              <div>
                <p class="font-semibold text-gray-900 text-sm">{t.name}</p>
                <p class="text-gray-500 text-xs">{t.title}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- We've got each other's backs -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-10 anim-fade-up">We've got each other's backs</h2>
      <div class="max-w-4xl mx-auto">
        <img src="/images/careers/Collage-pic.png" alt="GRG India team moments" class="w-full rounded-2xl anim-fade-in" data-anim-delay="100" />
      </div>
    </div>
  </section>

  <!-- Our Guiding Values -->
  <section class="py-16 md:py-20 pb-10 md:pb-12" style="background-color: #f9fafb;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-14 anim-fade-up">Our guiding values</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="flex flex-col items-center text-center p-6 rounded-xl border border-gray-200 bg-white hover:shadow-md transition-shadow anim-scale-in">
          <img src="/images/careers/We-re-passionate.png" alt="We're passionate" class="w-16 h-16 object-contain" />
          <h3 class="mt-4 text-base font-semibold text-[#0f1f3d]">We're passionate</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">Not one dull moment, we take a lot of pride and enthusiasm in everything we do.</p>
        </div>
        <div class="flex flex-col items-center text-center p-6 rounded-xl border border-gray-200 bg-white hover:shadow-md transition-shadow anim-scale-in" data-anim-delay="100">
          <img src="/images/careers/We-go-the-extra-mile.png" alt="We go the extra mile" class="w-16 h-16 object-contain" />
          <h3 class="mt-4 text-base font-semibold text-[#0f1f3d]">We go the extra mile</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">We do whatever it takes to deliver exceptional results that delight our customers.</p>
        </div>
        <div class="flex flex-col items-center text-center p-6 rounded-xl border border-gray-200 bg-white hover:shadow-md transition-shadow anim-scale-in" data-anim-delay="200">
          <img src="/images/careers/We-are-professional.png" alt="We're professional" class="w-16 h-16 object-contain" />
          <h3 class="mt-4 text-base font-semibold text-[#0f1f3d]">We're professional</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">We take ownership of the quality of work we deliver and how others perceive us.</p>
        </div>
        <div class="flex flex-col items-center text-center p-6 rounded-xl border border-gray-200 bg-white hover:shadow-md transition-shadow anim-scale-in" data-anim-delay="300">
          <img src="/images/careers/We-respect-others.png" alt="We respect others" class="w-16 h-16 object-contain" />
          <h3 class="mt-4 text-base font-semibold text-[#0f1f3d]">We respect others</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">We consider, care for and acknowledge our colleagues, customers, vendors and every other stakeholder.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section id="openings" class="py-10 md:py-16" style="background-color: #f9fafb;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 anim-fade-up">Open Positions</h2>
        <p class="mt-4 text-lg text-gray-600 anim-fade-up" data-anim-delay="100">
          We're always looking for talented people who want to make an impact. See what's open below.
        </p>
      </div>

      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-4">
        {openings.map((job, i) => (
          <a
            href={`/${job.slug}/`}
            class="block bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md hover:border-gray-300 transition-all group anim-fade-up"
            data-anim-delay={200 + i * 100}
          >
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-[#E41E3A] transition-colors">{job.title}</h3>
                <div class="mt-2 flex flex-wrap gap-3 text-sm text-gray-500">
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                    {job.department}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    {job.location}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    {job.type}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    {job.experience}
                  </span>
                </div>
              </div>
              <div class="shrink-0">
                <span class="inline-flex items-center gap-1 text-sm font-medium group-hover:text-[#E41E3A] transition-colors" style="color: #E41E3A;">
                  View Role
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
            </div>
            <p class="mt-3 text-sm text-gray-600 leading-relaxed">{job.summary}</p>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>

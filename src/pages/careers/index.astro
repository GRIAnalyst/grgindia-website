---
import Layout from '../layouts/Layout.astro';

const openings = [
  {
    title: 'Business Development Executive',
    slug: 'business-development-executive',
    department: 'Growth & Strategy',
    location: 'Mumbai, India',
    type: 'Full-time',
    experience: '1–2 years',
    summary: 'Drive new business opportunities in B2B SaaS sales for our incentive management platform, working with enterprise clients across India.',
  },
];

const perks = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5Z" /></svg>`,
    title: 'Central Mumbai Office',
    desc: 'Work from our Sewri office in the heart of Mumbai.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>`,
    title: 'Learning & Growth',
    desc: 'Continuous training, skill-building, and exposure to enterprise clients.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" /></svg>`,
    title: 'High-Impact Work',
    desc: 'Shape the product roadmap and work directly with India\'s top brands.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>`,
    title: 'Small Team, Big Ownership',
    desc: 'Lean team where your contributions are visible and valued from day one.',
  },
];
---

<Layout title="Careers at GRG India" description="Join our team and help build the future of incentive and reward management for India's top enterprises.">

  <!-- Hero -->
  <section style="background-color: #0f1f3d;" class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-widest uppercase" style="color: #E41E3A;">Careers</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-extrabold text-white leading-tight">
          Build the Future of<br />Incentive Technology
        </h1>
        <p class="mt-6 text-lg md:text-xl text-gray-300 max-w-2xl">
          Join a team that's helping India's top brands — from Tanishq to Dell — automate, gamify, and transform how they reward performance.
        </p>
        <a
          href="#openings"
          class="mt-8 inline-flex items-center gap-2 px-6 py-3 text-white font-semibold rounded-lg transition-colors"
          style="background-color: #E41E3A;"
          onmouseover="this.style.backgroundColor='#b8162e'"
          onmouseout="this.style.backgroundColor='#E41E3A'"
        >
          View Open Positions
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
      </div>
    </div>
    <!-- Decorative wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60L1440 60L1440 30C1200 0 960 10 720 30C480 50 240 60 0 30L0 60Z" fill="#f9fafb" />
      </svg>
    </div>
  </section>

  <!-- Why GRG India -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Why GRG India?</h2>
        <p class="mt-4 text-lg text-gray-600">
          We're a bootstrapped SaaS company that's grown to $800K+ ARR by solving real problems for real enterprises. Here's what makes working here different.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {perks.map((perk) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4" style="background-color: #fef2f2; color: #E41E3A;">
              <Fragment set:html={perk.icon} />
            </div>
            <h3 class="text-lg font-semibold text-gray-900">{perk.title}</h3>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">{perk.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section id="openings" class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Open Positions</h2>
        <p class="mt-4 text-lg text-gray-600">
          We're always looking for talented people who want to make an impact. See what's open below.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        {openings.map((job) => (
          <a
            href={`/careers/${job.slug}`}
            class="block bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md hover:border-gray-300 transition-all group"
          >
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-[#E41E3A] transition-colors">{job.title}</h3>
                <div class="mt-2 flex flex-wrap gap-3 text-sm text-gray-500">
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                    {job.department}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    {job.location}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    {job.type}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    {job.experience}
                  </span>
                </div>
              </div>
              <div class="shrink-0">
                <span class="inline-flex items-center gap-1 text-sm font-medium group-hover:text-[#E41E3A] transition-colors" style="color: #E41E3A;">
                  View Role
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
            </div>
            <p class="mt-3 text-sm text-gray-600 leading-relaxed">{job.summary}</p>
          </a>
        ))}
      </div>

      <!-- No more openings note -->
      <div class="max-w-3xl mx-auto mt-10 text-center">
        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <p class="text-gray-700 font-medium">Don't see the right role?</p>
          <p class="mt-2 text-sm text-gray-500">We're always interested in hearing from talented people. Send us your resume at <a href="mailto:hello@grgindia.in" class="font-medium" style="color: #E41E3A;">hello@grgindia.in</a></p>
        </div>
      </div>
    </div>
  </section>

</Layout>

---
import Layout from '../../layouts/Layout.astro';

const job = {
  title: 'Business Development Executive',
  department: 'Growth & Strategy',
  location: 'Mumbai, India',
  type: 'Full-time',
  experience: '1–2 years',
  reportsTo: 'Head of Growth and Strategy',
  posted: '2026-03-01',
};
---

<Layout title={`${job.title} — Careers at GRG India`} description="Join GRG India as a Business Development Executive. Drive new B2B SaaS sales for our incentive management platform.">

  <!-- Breadcrumb + Back -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/careers" class="hover:text-gray-900 transition-colors">Careers</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span class="text-gray-900 font-medium">{job.title}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid lg:grid-cols-3 gap-12">

      <!-- Main Content (2/3) -->
      <div class="lg:col-span-2">

        <!-- Header -->
        <div class="mb-10">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-block px-3 py-1 text-xs font-medium rounded-full" style="background-color: #fef2f2; color: #E41E3A;">{job.department}</span>
            <span class="inline-block px-3 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded-full">{job.type}</span>
            <span class="inline-block px-3 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded-full">{job.experience}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">{job.title}</h1>
          <div class="mt-4 flex flex-wrap gap-4 text-sm text-gray-500">
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              {job.location}
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              Reports to {job.reportsTo}
            </span>
          </div>
        </div>

        <!-- About Us -->
        <section class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4">About GRG India</h2>
          <div class="prose prose-gray max-w-none text-gray-600 leading-relaxed space-y-4">
            <p>
              GRG India is a SaaS company providing products in incentive and reward management. Our flagship product — <strong>My Incentives</strong> — helps companies engage and incentivize their sales teams, customers, and channel partners. Our clients include some of India's top brands across BFSI, FMCG, Construction, IT, Agro Chemicals, and Automotive industries.
            </p>
            <p>
              My Incentives is a B2B, no-code enterprise SaaS product. We automate the end-to-end sales and channel incentive process, typically for large companies with 2,000+ member strong frontline and channel sales teams.
            </p>
            <p>Specifically, we keep our clients' brands and sales top of mind via:</p>
            <ul class="list-disc pl-5 space-y-2 text-gray-600">
              <li><strong>Automating the admin hassle</strong> of executing and calculating sales incentives — our sophisticated, real-time engine ingests and transforms data and calculates incentives in real time</li>
              <li><strong>Gamifying and motivating</strong> frontline and channel sales teams</li>
              <li><strong>Providing visibility</strong> to regional sales leadership</li>
              <li><strong>Driving zero leakages and zero fraud</strong> in incentive payouts</li>
            </ul>
          </div>
        </section>

        <!-- What Makes This Role Great -->
        <section class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4">What Makes This Role Great</h2>
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: #E41E3A;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Work in a rapidly evolving industry where next-generation loyalty and incentive solutions have a huge impact</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: #E41E3A;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Contribute to shaping the product roadmap and bringing product vision to life</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: #E41E3A;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Direct exposure to enterprise clients including Tanishq, Dell, Adani Wilmar, and more</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Responsibilities -->
        <section class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4">What You'll Do</h2>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">1</span>
              <span>Identify and generate new business opportunities through research, networking, and outreach</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">2</span>
              <span>Build and maintain strong relationships with prospective and existing clients</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">3</span>
              <span>Understand client requirements and provide suitable product/service solutions</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">4</span>
              <span>Support in drafting proposals, presentations, and pricing strategies</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">5</span>
              <span>Collaborate with cross-functional teams to ensure successful client onboarding and delivery</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">6</span>
              <span>Achieve assigned sales targets and contribute to revenue growth</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">7</span>
              <span>Maintain accurate client interaction records, pipeline, and conversions in CRM systems</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">8</span>
              <span>Stay updated on industry trends, competitors, and market developments</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">9</span>
              <span>Actively participate in training, skill-building, and continuous learning initiatives</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-xs font-semibold text-gray-500 mt-0.5">10</span>
              <span>Represent the company in client meetings, conferences, and networking events</span>
            </li>
          </ul>
        </section>

        <!-- Requirements -->
        <section class="mb-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4">What You'll Need</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Experience & Education</h3>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Prior exposure to B2B sales and concept selling</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Bachelor's degree (or higher) in Business Administration or relevant discipline</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>1–2 years of experience in CRM, SaaS, Rewards, Loyalty, or Incentive domain</span>
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Skills & Qualities</h3>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Strong interpersonal and communication skills — fluent in English (written and oral)</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Ability to develop strong relationships and build an industry or functional network</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Negotiation skills, resource stewardship, and an ability to handle ambiguity</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Technology mindset and data-driven approach to formulating new age solutions</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
                  <span>Keen sales and marketing acumen</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

      </div>

      <!-- Sidebar (1/3) -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">

          <!-- Apply Card -->
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Interested?</h3>
            <a
              href="mailto:contactus@grgindia.in?subject=Application%3A%20Business%20Development%20Executive"
              class="block w-full text-center px-5 py-3 text-white font-semibold rounded-lg transition-colors"
              style="background-color: #E41E3A;"
              onmouseover="this.style.backgroundColor='#b8162e'"
              onmouseout="this.style.backgroundColor='#E41E3A'"
            >
              Apply for This Role
            </a>
            <p class="mt-3 text-xs text-gray-500 text-center">
              Send your resume to contactus@grgindia.in
            </p>
          </div>

          <!-- Role Summary Card -->
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-6">
            <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Role Details</h3>
            <dl class="space-y-4 text-sm">
              <div>
                <dt class="text-gray-500">Department</dt>
                <dd class="mt-0.5 text-gray-900 font-medium">{job.department}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Location</dt>
                <dd class="mt-0.5 text-gray-900 font-medium">{job.location}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Employment Type</dt>
                <dd class="mt-0.5 text-gray-900 font-medium">{job.type}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Experience</dt>
                <dd class="mt-0.5 text-gray-900 font-medium">{job.experience}</dd>
              </div>
              <div>
                <dt class="text-gray-500">Reports To</dt>
                <dd class="mt-0.5 text-gray-900 font-medium">{job.reportsTo}</dd>
              </div>
            </dl>
          </div>

          <!-- Back link -->
          <a href="/careers" class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Back to all openings
          </a>

        </div>
      </div>

    </div>
  </div>

</Layout>

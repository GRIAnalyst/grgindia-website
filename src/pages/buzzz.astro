---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Buzzz – Employee Rewards & Recognition" description="Buzzz by GRG India — an all-in-one employee rewards and recognition platform to boost motivation, engagement, and workplace culture.">

  <!-- ==================== HERO ==================== -->
  <section class="bg-[#f5f5f8] relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,100 C360,180 1080,20 1440,100 L1440,200 L0,200 Z" fill="#ebebf0" opacity="0.6"/>
        <path d="M0,140 C400,80 1000,160 1440,120 L1440,200 L0,200 Z" fill="#e2e2ea" opacity="0.4"/>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold leading-tight text-[#0f1f3d]">
            All-in-One Rewards & Recognition Platform to Boost Employee Motivation
          </h1>
          <p class="mt-6 text-lg text-[#4a5568]">
            Drive peer-to-peer recognition, celebrate milestones, and build a culture of appreciation — all from one platform.
          </p>
          <a
            href="/book-a-demo"
            class="mt-8 inline-block px-8 py-3 bg-[#E41E3A] text-white font-semibold rounded-lg hover:bg-[#b8162e] transition-colors"
          >
            Book a Demo
          </a>
        </div>
        <div>
          <img src="/images/buzzz/hero-banner.png" alt="Buzzz platform overview" class="w-full h-auto" />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CLIENT LOGOS ==================== -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-semibold uppercase tracking-widest text-gray-400 mb-8">Trusted by leading brands</p>
      <div class="flex flex-wrap justify-center items-center gap-8">
        {[
          'Adani-Wilmar', 'Caratlane', 'Dell', 'Latentview', 'Mahindra',
          'PRESTIGE', 'gulf', 'sbi-card', 'tanishq', 'titan',
        ].map((name) => (
          <img
            src={`/images/logos/${name}.png`}
            alt={name}
            class="max-h-10 w-auto object-contain grayscale hover:grayscale-0 transition-[filter] duration-300"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-[#0f1f3d]">How Buzzz Works</h2>
      <p class="mt-4 text-center text-gray-600 max-w-2xl mx-auto">
        Get up and running in two simple steps — set up your recognition programs and watch engagement soar.
      </p>
      <div class="mt-14 grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center">
          <img src="/images/buzzz/how-it-works-01.png" alt="Step 1 – Set up recognition programs" class="w-full max-w-md mx-auto" />
          <div class="mt-6">
            <span class="inline-block w-10 h-10 rounded-full bg-[#E41E3A] text-white font-bold text-lg leading-10 text-center">1</span>
            <h3 class="mt-3 text-xl font-semibold text-[#0f1f3d]">Set Up Your Programs</h3>
            <p class="mt-2 text-gray-600">Configure recognition categories, point structures, and reward catalogs tailored to your organization.</p>
          </div>
        </div>
        <div class="text-center">
          <img src="/images/buzzz/how-it-works-02.png" alt="Step 2 – Engage and reward" class="w-full max-w-md mx-auto" />
          <div class="mt-6">
            <span class="inline-block w-10 h-10 rounded-full bg-[#E41E3A] text-white font-bold text-lg leading-10 text-center">2</span>
            <h3 class="mt-3 text-xl font-semibold text-[#0f1f3d]">Engage & Reward</h3>
            <p class="mt-2 text-gray-600">Employees recognize peers, earn points, redeem rewards, and participate in a vibrant social feed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== 4 PRODUCT FEATURES (alternating) ==================== -->
  <section class="py-16 md:py-24 bg-[#f8f8f8]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-[#0f1f3d]">
        Gamify Employee Rewards & Recognition
      </h2>
      <p class="mt-4 text-center text-gray-600 max-w-3xl mx-auto">
        Four powerful modules that work together to create a culture of appreciation and high performance.
      </p>

      <div class="mt-16 space-y-20">

        <!-- Feature 1: Social Recognition — text left, image right -->
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div class="px-2 md:px-6">
            <h3 class="text-2xl font-bold text-[#0f1f3d]">Social Recognition</h3>
            <p class="mt-4 text-lg text-gray-600">
              Empower employees to recognize each other's contributions on a social feed. Send buzzzes, appreciation posts, and celebrate wins publicly across the organization.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Peer-to-peer recognition with points</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Public appreciation wall & social feed</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">E-certificates and congratulations popups</span>
              </li>
            </ul>
          </div>
          <img src="/images/buzzz/social-recognition.png" alt="Social Recognition feature" class="w-full max-w-lg mx-auto" />
        </div>

        <!-- Feature 2: Mood-o-Meter — image left, text right -->
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <img src="/images/buzzz/mood-o-meter.png" alt="Mood-o-Meter feature" class="w-full max-w-lg mx-auto order-2 md:order-1" />
          <div class="order-1 md:order-2 px-2 md:px-6">
            <h3 class="text-2xl font-bold text-[#0f1f3d]">Mood-o-Meter</h3>
            <p class="mt-4 text-lg text-gray-600">
              Track employee sentiment in real time with quick mood check-ins. Monitor engagement and happiness trends to proactively address workplace concerns.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Quick daily mood check-ins</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Engagement & happiness trend charts</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Early warning for disengagement</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Feature 3: Gamification — text left, image right -->
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div class="px-2 md:px-6">
            <h3 class="text-2xl font-bold text-[#0f1f3d]">Gamification</h3>
            <p class="mt-4 text-lg text-gray-600">
              Spark healthy competition with leaderboards, badges, and achievement tracking. Gamify participation to keep engagement levels high across teams.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Leaderboards with top performers</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Badges, certificates & achievements</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Organization pulse & team rankings</span>
              </li>
            </ul>
          </div>
          <img src="/images/buzzz/gamification.png" alt="Gamification feature" class="w-full max-w-lg mx-auto" />
        </div>

        <!-- Feature 4: Analytics & Dashboard — image left, text right -->
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <img src="/images/buzzz/analytics-dashboard.png" alt="Analytics & Dashboard feature" class="w-full max-w-lg mx-auto order-2 md:order-1" />
          <div class="order-1 md:order-2 px-2 md:px-6">
            <h3 class="text-2xl font-bold text-[#0f1f3d]">Analytics & Dashboard</h3>
            <p class="mt-4 text-lg text-gray-600">
              Get real-time visibility into recognition trends, participation rates, and points distribution. Make data-driven decisions to optimize your rewards program.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Visitor & engagement trend charts</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Monthly points summary & distribution</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-[#E41E3A] shrink-0"></span>
                <span class="text-gray-600">Buzzz activity & recognition reports</span>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== WAYS TO USE BUZZZ (Icon Grid) ==================== -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-[#0f1f3d]">
        There's More Than One Way to Motivate Employees
      </h2>
      <p class="mt-4 text-center text-gray-600 max-w-2xl mx-auto">
        Buzzz gives you multiple tools to drive recognition and engagement across your organization.
      </p>
      <div class="mt-14 grid grid-cols-2 sm:grid-cols-4 gap-8">
        {[
          { img: '/images/buzzz/ways/peer-recognition.png', title: 'Peer Recognition' },
          { img: '/images/buzzz/ways/celebrate-milestones.png', title: 'Celebrate Milestones' },
          { img: '/images/buzzz/ways/contests-programs.png', title: 'Contests & Programs' },
          { img: '/images/buzzz/ways/award-nominations.png', title: 'Award Nominations' },
          { img: '/images/buzzz/ways/reinforce-core-values.png', title: 'Reinforce Core Values' },
          { img: '/images/buzzz/ways/send-audio-video.png', title: 'Send Audio/Video' },
          { img: '/images/buzzz/ways/send-e-certificate.png', title: 'Send e-Certificates' },
          { img: '/images/buzzz/ways/spot-award.png', title: 'Spot Awards' },
        ].map((item) => (
          <div class="flex flex-col items-center text-center p-4 rounded-xl hover:shadow-md transition-shadow">
            <img src={item.img} alt={item.title} class="w-20 h-20 object-contain" />
            <h3 class="mt-4 text-sm font-semibold text-[#0f1f3d]">{item.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== WHY BUZZZ ==================== -->
  <section class="py-16 md:py-24 bg-[#f5f5f8]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-[#0f1f3d]">Why Choose Buzzz?</h2>
      <p class="mt-4 text-center text-gray-600 max-w-2xl mx-auto">
        A platform built to make employee recognition effortless, scalable, and impactful.
      </p>
      <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
        {[
          {
            img: '/images/buzzz/automate-programs.png',
            title: 'Automate Programs',
            desc: 'Set up recognition and rewards programs that run on autopilot — from milestone awards to anniversary celebrations.',
          },
          {
            img: '/images/buzzz/customize-everything.png',
            title: 'Customize Everything',
            desc: 'Tailor every aspect of your rewards program — branding, categories, point structures, and approval workflows.',
          },
          {
            img: '/images/buzzz/drive-participation.png',
            title: 'Drive Participation',
            desc: 'Boost engagement with gamification, nudges, and social features that encourage everyone to participate.',
          },
          {
            img: '/images/buzzz/integrate-with-any-platform.png',
            title: 'Integrate with Any Platform',
            desc: 'Connect Buzzz with your existing HRMS, Slack, Teams, or any platform through flexible API integrations.',
          },
        ].map((item) => (
          <div class="flex flex-col items-center text-center bg-white rounded-xl p-6 shadow-sm">
            <img src={item.img} alt={item.title} class="w-24 h-24 object-contain" />
            <h3 class="mt-5 text-lg font-semibold text-[#0f1f3d]">{item.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f1f3d]">Ready to Build a Culture of Recognition?</h2>
      <p class="mt-4 text-gray-600 max-w-xl mx-auto">
        See how Buzzz can transform employee engagement and motivation at your organization.
      </p>
      <a
        href="/book-a-demo"
        class="mt-8 inline-block px-8 py-3 bg-[#E41E3A] text-white font-semibold rounded-lg hover:bg-[#b8162e] transition-colors"
      >
        Book a Demo
      </a>
    </div>
  </section>

</Layout>

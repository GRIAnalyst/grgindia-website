---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Buzzz" description="Buzzz - Channel loyalty and engagement platform by GRG India.">
  <section class="bg-gradient-to-br from-purple-600 to-purple-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold">Buzzz</h1>
        <p class="mt-6 text-lg md:text-xl text-purple-100">
          A comprehensive channel loyalty and engagement platform that motivates your partners, dealers, and distributors to sell more.
        </p>
        <a
          href="/book-a-demo"
          class="mt-8 inline-block px-6 py-3 bg-white text-purple-700 font-semibold rounded-lg hover:bg-purple-50"
        >
          Request a Demo
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center">Key Features</h2>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: 'Points & Rewards', desc: 'Flexible reward structures with an extensive redemption catalog.' },
          { title: 'Gamification', desc: 'Leaderboards, badges, and challenges to keep partners engaged.' },
          { title: 'Real-time Analytics', desc: 'Track partner performance and program ROI in real time.' },
          { title: 'Multi-tier Programs', desc: 'Create tiered loyalty programs for different partner segments.' },
          { title: 'Claims Management', desc: 'Streamlined claims processing with automated validation.' },
          { title: 'Communication Hub', desc: 'Engage partners through targeted messages and notifications.' },
        ].map((feature) => (
          <div class="p-6 border border-gray-200 rounded-xl">
            <h3 class="text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-gray-600">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

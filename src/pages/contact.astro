---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Get in touch with GRG India — we'd love to hear from you.">

  <!-- Hero Bar -->
  <section class="bg-[#0f1f3d] py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl font-bold text-white">Contact Us</h1>
      <p class="mt-2 text-base text-gray-300">Have a question? Our team is ready to help.</p>
    </div>
  </section>

  <!-- Two-Column Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- LEFT COLUMN -->
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight mb-8">
            GRG India has motivated<br />
            50,000+ people across 20+<br />
            countries to outperform!
          </h2>
          <div class="space-y-6 text-gray-600">
            <p class="text-lg">We help enterprises design, automate, and manage rewards, recognition, and incentive programs that drive real business outcomes.</p>
            <div class="grid grid-cols-2 gap-6 pt-2">
              <div>
                <p class="text-3xl font-bold text-[#0f1f3d]">20+</p>
                <p class="text-sm text-gray-500 mt-1">Years of Experience</p>
              </div>
              <div>
                <p class="text-3xl font-bold text-[#0f1f3d]">100+</p>
                <p class="text-sm text-gray-500 mt-1">Enterprise Clients</p>
              </div>
              <div>
                <p class="text-3xl font-bold text-[#0f1f3d]">500K+</p>
                <p class="text-sm text-gray-500 mt-1">Active Users</p>
              </div>
              <div>
                <p class="text-3xl font-bold text-[#0f1f3d]">1.5M+</p>
                <p class="text-sm text-gray-500 mt-1">Annual Awards</p>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div>
          <!-- Form Card -->
          <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 md:p-10">
            <h3 class="text-xl font-bold text-gray-900 mb-6">Send us a message</h3>

            <form class="space-y-5">
              <!-- First Name / Last Name -->
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    required
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                  />
                </div>
              </div>

              <!-- Work Email -->
              <div>
                <label for="work-email" class="block text-sm font-medium text-gray-700 mb-1">Work Email</label>
                <input
                  type="email"
                  id="work-email"
                  name="work-email"
                  required
                  placeholder="you@company.com"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                />
              </div>

              <!-- Phone Number -->
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+91 XXXXX XXXXX"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                />
              </div>

              <!-- Company Name -->
              <div>
                <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company Name</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                />
              </div>

              <!-- I'm interested in -->
              <div>
                <label for="interest" class="block text-sm font-medium text-gray-700 mb-1">I'm interested in</label>
                <select
                  id="interest"
                  name="interest"
                  required
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors bg-white"
                >
                  <option value="" disabled selected>Select a product</option>
                  <option value="my-incentives">My Incentives</option>
                  <option value="buzzz">Buzzz</option>
                  <option value="both">Both Products</option>
                  <option value="general">General Inquiry</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  placeholder="Tell us about your use case, team size, or anything else that would help us prepare..."
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full bg-[#E41E3A] text-white font-semibold py-3 rounded-lg hover:bg-[#c9182f] transition-colors"
              >
                Send Message &rarr;
              </button>
            </form>

            <p class="text-xs text-gray-400 text-center mt-3">
              By submitting, you agree to our Privacy Policy. We'll never share your data.
            </p>
          </div>

          <!-- Contact Details -->
          <div class="mt-6 space-y-4">
            <div class="flex items-start gap-3">
              <div class="shrink-0 p-2 bg-red-50 rounded-lg">
                <svg class="w-5 h-5 text-[#E41E3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <p class="text-sm text-gray-600">Satya House, 402, Hi-Tech IT Park, 2nd &amp; 4th Floor, Sewri West, Mumbai 400 015</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="shrink-0 p-2 bg-red-50 rounded-lg">
                <svg class="w-5 h-5 text-[#E41E3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <p class="text-sm text-gray-600">hello@grgindia.in</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="shrink-0 p-2 bg-red-50 rounded-lg">
                <svg class="w-5 h-5 text-[#E41E3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              </div>
              <p class="text-sm text-gray-600">www.grgindia.in</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us - Leaders In Incentives, Rewards & Loyalty Programs | GRG India"
  description="Get in touch with GRG India. Talk to sales for product information, book a demo, or reach our customer support team for existing customers."
  canonical="https://www.grgindia.in/contact-us/"
>

  <!-- ==================== SINGLE FOLD: FORM + SIDEBAR ==================== -->
  <section class="py-10 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-stretch">

        <!-- LEFT: Form (3/5 width) -->
        <div class="lg:col-span-3">
          <div class="rounded-2xl p-7 md:p-9 bg-white shadow-lg border-l-4 border-l-[#E41E3A] anim-fade-up">
            <h1 class="text-2xl md:text-3xl font-bold text-[#0f1f3d] mb-6">Get in touch with our team</h1>

            <form class="space-y-4">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-[#E41E3A]">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                />
              </div>

              <!-- Email + Phone on same row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="work-email" class="block text-sm font-medium text-gray-700 mb-1">Work Email <span class="text-[#E41E3A]">*</span></label>
                  <input
                    type="email"
                    id="work-email"
                    name="work-email"
                    required
                    placeholder="you@company.com"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number <span class="text-[#E41E3A]">*</span></label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    placeholder="+91 XXXXX XXXXX"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                  />
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  placeholder="Tell us about your use case, team size, or anything else..."
                  class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-1 focus:ring-[#E41E3A] outline-none transition-colors"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full bg-[#E41E3A] text-white font-semibold py-3 rounded-lg hover:bg-[#c9182f] transition-colors text-sm cursor-pointer"
              >
                Submit
              </button>
            </form>

            <p class="text-xs text-gray-400 text-center mt-3">
              By submitting, you agree to our <a href="/privacy-policy" class="underline hover:text-gray-300">Privacy Policy</a>. We'll never share your data.
            </p>
          </div>
        </div>

        <!-- RIGHT: Sidebar (2/5 width) -->
        <div class="lg:col-span-2 flex flex-col space-y-6 h-full anim-fade-up" data-anim-delay="200">

          <!-- Existing Customer Section -->
          <div>
            <h2 class="text-base font-bold text-[#0f1f3d] mb-3">Existing customer?</h2>
            <p class="text-sm text-gray-600 mb-3">Log in to your platform to raise a support ticket directly.</p>

            <div class="space-y-2.5">
              <a href="https://clients.myincentives.in/" target="_blank" rel="noopener noreferrer"
                class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 bg-white hover:shadow-md hover:border-[#E41E3A]/30 transition-all">
                <div class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #E41E3A, #b8162e);">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-[#0f1f3d] group-hover:text-[#E41E3A] transition-colors">My Incentives</p>
                  <p class="text-xs text-gray-500">Log in to raise a ticket</p>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-[#E41E3A] ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>

              <a href="https://clients.letsbuzzz.com/" target="_blank" rel="noopener noreferrer"
                class="group flex items-center gap-3 p-3.5 rounded-xl border border-gray-200 bg-white hover:shadow-md hover:border-[#E41E3A]/30 transition-all">
                <div class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #E41E3A, #b8162e);">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-[#0f1f3d] group-hover:text-[#E41E3A] transition-colors">Buzzz</p>
                  <p class="text-xs text-gray-500">Log in to raise a ticket</p>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-[#E41E3A] ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>

          <!-- Divider -->
          <hr class="border-gray-200" />

          <!-- Anything Else -->
          <div>
            <h2 class="text-base font-bold text-[#0f1f3d] mb-1">Anything else?</h2>
            <p class="text-sm text-gray-600">
              Write to us at
              <a href="mailto:contactus@grgindia.in" class="font-semibold text-[#E41E3A] hover:underline">contactus@grgindia.in</a>
            </p>
          </div>

          <!-- Divider -->
          <hr class="border-gray-200" />

          <!-- Office Details -->
          <div class="space-y-2.5 text-sm text-gray-600">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-[#E41E3A] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span>Satya House, 402, Hi-Tech IT Park, Sewri West, Mumbai 400 015</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#E41E3A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" /></svg>
              <span>www.grgindia.in</span>
            </div>
          </div>

          <!-- Trust Signal -->
          <div class="flex-1"></div>
          <div class="rounded-xl bg-[#f9fafb] p-4">
            <div class="flex items-center gap-2.5 mb-1">
              <svg class="w-4 h-4 text-[#E41E3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              <span class="text-sm font-semibold text-[#0f1f3d]">Trusted by 100+ enterprises</span>
            </div>
            <p class="text-xs text-gray-500">20+ years of experience. ISO 27001 certified.</p>
          </div>

        </div>

      </div>
    </div>
  </section>

</Layout>

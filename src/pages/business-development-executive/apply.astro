---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Apply — Business Development Executive | GRG India" description="Apply for the Business Development Executive role at GRG India.">

  <section class="min-h-screen bg-[#f5f5f8] py-12 md:py-20">
    <div class="max-w-lg mx-auto px-4 sm:px-6">

      <!-- Back link -->
      <a href="/business-development-executive/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-6 anim-fade-up">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Back to role details
      </a>

      <!-- Form Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden anim-fade-up" data-anim-delay="100">

        <!-- Header -->
        <div class="px-8 pt-8 pb-5">
          <h1 class="text-2xl font-bold text-[#0f1f3d]">Apply for this role</h1>
          <p class="mt-1 text-gray-500">Business Development Executive &middot; Mumbai &middot; Full-time</p>
        </div>

        <!-- Form -->
        <form class="px-8 pb-8 space-y-5" id="apply-form">

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address <span class="text-[#E41E3A]">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-2 focus:ring-[#E41E3A]/20 outline-none transition-all"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone Number <span class="text-[#E41E3A]">*</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="+91 XXXXX XXXXX"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:border-[#E41E3A] focus:ring-2 focus:ring-[#E41E3A]/20 outline-none transition-all"
            />
          </div>

          <!-- CV Upload -->
          <div>
            <label for="cv" class="block text-sm font-medium text-gray-700 mb-1.5">Upload Your CV <span class="text-[#E41E3A]">*</span></label>
            <input
              type="file"
              id="cv"
              name="cv"
              required
              accept=".pdf,.doc,.docx"
              class="hidden"
            />
            <label
              for="cv"
              id="cv-label"
              class="flex items-center gap-3 w-full border border-dashed border-gray-300 rounded-lg px-4 py-4 cursor-pointer hover:border-[#E41E3A] hover:bg-red-50/20 transition-all"
            >
              <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
              <div>
                <p class="text-sm"><span class="font-medium text-[#E41E3A]">Choose a file</span> <span class="text-gray-500">or drag and drop</span></p>
                <p class="text-xs text-gray-400 mt-0.5">PDF, DOC, or DOCX (max 5 MB)</p>
              </div>
            </label>
            <p id="cv-filename" class="hidden mt-2 text-sm text-gray-600 flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span id="cv-name-text"></span>
            </p>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-[#E41E3A] text-white font-semibold py-3 rounded-lg hover:bg-[#b8162e] transition-colors text-sm cursor-pointer"
          >
            Submit Application
          </button>

          <p class="text-xs text-gray-400 text-center pb-1">
            By submitting, you agree to our <a href="/privacy-policy/" class="underline hover:text-gray-600">Privacy Policy</a>.
          </p>
        </form>

        <!-- Success state -->
        <div id="apply-success" class="hidden px-8 py-14 text-center">
          <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900">Application Submitted</h2>
          <p class="mt-2 text-sm text-gray-600">Thank you for your interest. We'll review your application and get back to you soon.</p>
          <a href="/careers/" class="mt-5 inline-block text-sm font-medium text-[#E41E3A] hover:underline">Back to Careers</a>
        </div>

      </div>
    </div>
  </section>

<script>
  const cvInput = document.getElementById('cv');
  const cvLabel = document.getElementById('cv-label');
  const cvFilename = document.getElementById('cv-filename');
  const cvNameText = document.getElementById('cv-name-text');

  cvInput?.addEventListener('change', () => {
    if (cvInput.files && cvInput.files.length > 0) {
      if (cvNameText) cvNameText.textContent = cvInput.files[0].name;
      cvFilename?.classList.remove('hidden');
      if (cvLabel) {
        cvLabel.classList.remove('border-gray-300');
        cvLabel.classList.add('border-green-400', 'bg-green-50/30');
      }
    }
  });

  const form = document.getElementById('apply-form');
  const success = document.getElementById('apply-success');
  const submitBtn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
    }

    const formData = new FormData(form);
    formData.append('role', 'Business Development Executive');

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        body: formData,
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        throw new Error();
      }
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Application';
      }
      alert('Something went wrong. Please try again or email GRI-Hr@grgindia.in directly.');
    }
  });
</script>

</Layout>

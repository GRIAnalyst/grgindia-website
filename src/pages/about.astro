---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="Learn about GRG India and our mission.">
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-bold">About GRG India</h1>
        <p class="mt-6 text-lg text-gray-600">
          GRG India is a leading provider of channel incentive and loyalty solutions, helping enterprises automate and optimize their partner programs.
        </p>
      </div>

      <div class="mt-16 grid md:grid-cols-3 gap-8">
        {[
          { title: 'Our Mission', desc: 'To empower businesses with intelligent technology that drives channel partner engagement and revenue growth.' },
          { title: 'Our Vision', desc: 'To be the most trusted platform for channel incentive management across industries worldwide.' },
          { title: 'Our Values', desc: 'Innovation, integrity, customer-centricity, and a relentless focus on delivering measurable outcomes.' },
        ].map((item) => (
          <div class="p-8 bg-gray-50 rounded-xl">
            <h2 class="text-xl font-semibold">{item.title}</h2>
            <p class="mt-3 text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

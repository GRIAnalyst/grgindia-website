---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - GRG India" description="The page you're looking for doesn't exist.">
  <section class="min-h-[60vh] flex items-center justify-center bg-white">
    <div class="max-w-md mx-auto px-4 text-center">
      <p class="text-6xl font-bold text-[#E41E3A]">404</p>
      <h1 class="mt-4 text-2xl font-bold text-[#0f1f3d]">Page not found</h1>
      <p class="mt-3 text-gray-600">The page you're looking for doesn't exist or has been moved.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-block px-6 py-3 bg-[#E41E3A] text-white font-semibold rounded-lg hover:bg-[#b8162e] transition-colors">
          Go Home
        </a>
        <a href="/contact-us/" class="inline-block px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Home - Leaders In Incentives, Rewards & Loyalty Programs | GRG India"
  description="Employee rewards and incentives management tools for sales incentive programs, sales team motivation, employee incentives programs & more"
  canonical="https://www.grgindia.in/"
>
  <!-- Hero -->
  <section class="bg-[#f5f5f8] relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,100 C360,180 1080,20 1440,100 L1440,200 L0,200 Z" fill="#ebebf0" opacity="0.6"/>
        <path d="M0,140 C400,80 1000,160 1440,120 L1440,200 L0,200 Z" fill="#e2e2ea" opacity="0.4"/>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="anim-fade-up text-4xl md:text-5xl font-bold leading-tight text-[#0f1f3d]">
            The Smartest Way to
            <br />
            <span id="hero-typed" class="text-[#E41E3A]">Manage</span><span id="hero-cursor" class="text-[#E41E3A] font-light">|</span>
            <br />
            Rewards &amp; Incentives
          </h1>
          <p class="anim-fade-up mt-6 text-lg text-[#4a5568]" data-anim-delay="150">
            Motivate and boost the performance of your employees and revenue generating teams with our plug-and-play, zero-code tools.
          </p>
          <a
            href="/book-a-demo"
            class="anim-fade-up mt-8 inline-block px-8 py-3 bg-[#E41E3A] text-white font-semibold rounded-lg hover:bg-[#b8162e]"
            data-anim-delay="300"
          >
            Book a Demo
          </a>
        </div>
        <div class="anim-slide-right" data-anim-delay="200">
          <img src="/images/home-banner.png" alt="GRG India platform" class="w-full h-auto" />
        </div>
      </div>
    </div>
  </section>

  <!-- Client Logos Strip -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="anim-fade-up text-3xl md:text-4xl font-bold text-center text-[#0f1f3d] mb-8">Trusted by</h2>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-8 md:gap-10 items-center justify-items-center">
        <img src="/images/logos/sbi-card.png" alt="SBI Card" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="0" />
        <img src="/images/logos/hdfc-bank.png" alt="HDFC Bank" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="50" />
        <img src="/images/logos/Dell.png" alt="Dell" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="100" />
        <img src="/images/logos/fujitsu.png" alt="Fujitsu" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="150" />
        <img src="/images/logos/godrej.png" alt="Godrej" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="200" />
        <img src="/images/logos/apar.jpg" alt="APAR" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="250" style="mix-blend-mode:multiply" />
        <img src="/images/logos/schneider-electric.png" alt="Schneider Electric" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="300" />
        <img src="/images/logos/dalmia.png" alt="Dalmia" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="350" />
        <img src="/images/logos/PRESTIGE.png" alt="Prestige" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="400" />
        <img src="/images/logos/gulf.png" alt="Gulf" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="450" />
        <img src="/images/logos/tafe.png" alt="TAFE" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="500" />
        <img src="/images/logos/Mahindra.png" alt="Mahindra" class="anim-scale-in h-12 w-full object-contain grayscale hover:grayscale-0 transition-[filter] duration-300" data-anim-delay="550" />
      </div>
    </div>
  </section>

  <!-- Loyalty Segments -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="anim-fade-up text-3xl md:text-4xl font-bold text-center">Build loyalty among those who matter!</h2>
      <p class="anim-fade-up mt-4 text-center text-gray-600 max-w-3xl mx-auto" data-anim-delay="100">
        With full-stack solutions for rewards, recognition, incentives and commission management, you can seamlessly drive trust and loyalty among all your stakeholders.
      </p>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Channel Partners', img: '/images/segments/channel-partners.png', desc: "Incentivize your channel partners, franchise stores, dealers, and distributors through a structured loyalty program - that's automated & managed digitally." },
          { title: 'Sales Teams', img: '/images/segments/sales-teams.png', desc: 'Motivate your sales teams to drive higher revenues by automating sales commission and incentive management for timely and hassle-free payouts.' },
          { title: 'Retail Stores', img: '/images/segments/retail-stores.png', desc: "Keep the frontline employees at your stores and outlets motivated with regular incentives and rewards." },
          { title: 'Influencers', img: '/images/segments/influencers.png', desc: 'Drive sales through influencer-led programs with automated commission tracking and hassle-free payouts.' },
        ].map((card, i) => (
          <div class="anim-fade-up border border-gray-200 rounded-xl shadow-sm overflow-hidden" data-anim-delay={String(i * 100)}>
            <img src={card.img} alt={card.title} class="w-full aspect-square object-cover" />
            <div class="p-6">
              <h3 class="text-lg font-semibold">{card.title}</h3>
              <p class="mt-2 text-sm text-gray-600">{card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features (Tabbed) -->
  <section class="py-12 md:py-16 bg-[#f8f8f8]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="anim-fade-up text-3xl md:text-4xl font-bold text-center text-[#0f1f3d] mb-8">Automate and manage rewards & incentives programs from scratch</h2>

      <div class="anim-fade-up" data-anim-delay="150">
        <!-- Mobile: horizontal pill tabs (visible below lg) -->
        <div class="flex flex-wrap justify-center gap-2 mb-6 lg:hidden" role="tablist">
          <button role="tab" aria-selected="true" data-tab="campaigns" class="feature-tab px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[#E41E3A] text-white shadow-md">Campaigns</button>
          <button role="tab" aria-selected="false" data-tab="gamify" class="feature-tab px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-white text-[#0f1f3d] border border-gray-200">Gamification</button>
          <button role="tab" aria-selected="false" data-tab="rewards" class="feature-tab px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-white text-[#0f1f3d] border border-gray-200">Rewards</button>
          <button role="tab" aria-selected="false" data-tab="social" class="feature-tab px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-white text-[#0f1f3d] border border-gray-200">Recognition</button>
        </div>

        <!-- Desktop: vertical tabs left + panel right -->
        <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-8">
          <!-- Vertical tab list (visible at lg+) -->
          <div class="hidden lg:block pt-2" role="tablist">
            <div class="border-l-2 border-gray-200">
              <button role="tab" aria-selected="true" data-tab="campaigns" class="feature-tab w-full text-left px-5 py-3 -ml-[2px] border-l-2 border-[#E41E3A] text-[#0f1f3d] font-semibold text-sm bg-[#E41E3A]/5 transition-all duration-200">
                Create Multiple Campaigns
              </button>
              <button role="tab" aria-selected="false" data-tab="gamify" class="feature-tab w-full text-left px-5 py-3 -ml-[2px] border-l-2 border-transparent text-gray-500 font-medium text-sm hover:text-[#0f1f3d] hover:bg-gray-50 transition-all duration-200">
                Gamify Loyalty Programs
              </button>
              <button role="tab" aria-selected="false" data-tab="rewards" class="feature-tab w-full text-left px-5 py-3 -ml-[2px] border-l-2 border-transparent text-gray-500 font-medium text-sm hover:text-[#0f1f3d] hover:bg-gray-50 transition-all duration-200">
                Global Reward Catalog
              </button>
              <button role="tab" aria-selected="false" data-tab="social" class="feature-tab w-full text-left px-5 py-3 -ml-[2px] border-l-2 border-transparent text-gray-500 font-medium text-sm hover:text-[#0f1f3d] hover:bg-gray-50 transition-all duration-200">
                Drive Social Recognition
              </button>
            </div>
          </div>

          <!-- Panels -->
          <div>
            <div data-panel="campaigns" class="feature-panel">
              <div class="grid md:grid-cols-[1fr_1fr] gap-6 items-center bg-white rounded-2xl p-6 md:p-8 shadow-sm">
                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-[#0f1f3d]">Create multiple campaigns</h3>
                  <p class="mt-3 text-sm text-gray-600 leading-relaxed">
                    Publish multiple rewards or incentive campaigns with ease. From complex calculations to paperwork and disbursement — everything can be automated.
                  </p>
                  <ul class="mt-4 space-y-2">
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Target-based, slab-based, or custom incentive structures</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Automate calculations and disbursement end-to-end</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Run multiple campaigns simultaneously with zero overlap</span>
                    </li>
                  </ul>
                </div>
                <div class="flex items-center justify-center">
                  <img src="/images/features/create-campaigns.png" alt="Create multiple campaigns" class="w-full max-w-sm" />
                </div>
              </div>
            </div>

            <div data-panel="gamify" class="feature-panel hidden">
              <div class="grid md:grid-cols-[1fr_1fr] gap-6 items-center bg-white rounded-2xl p-6 md:p-8 shadow-sm">
                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-[#0f1f3d]">Gamify loyalty programs</h3>
                  <p class="mt-3 text-sm text-gray-600 leading-relaxed">
                    Make reaching targets fun and competitive with leaderboards, points, badges, polls and votes, and so much more.
                  </p>
                  <ul class="mt-4 space-y-2">
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Real-time leaderboards with tier-based rankings</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Digital badges and milestone achievements</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Interactive quizzes, polls, and knowledge challenges</span>
                    </li>
                  </ul>
                </div>
                <div class="flex items-center justify-center">
                  <img src="/images/features/gamify-loyalty.png" alt="Gamify loyalty programs" class="w-full max-w-sm" />
                </div>
              </div>
            </div>

            <div data-panel="rewards" class="feature-panel hidden">
              <div class="grid md:grid-cols-[1fr_1fr] gap-6 items-center bg-white rounded-2xl p-6 md:p-8 shadow-sm">
                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-[#0f1f3d]">Global reward catalog</h3>
                  <p class="mt-3 text-sm text-gray-600 leading-relaxed">
                    Give your teams the freedom to choose from thousands of rewards — vouchers, experiences, and more — across multiple countries.
                  </p>
                  <ul class="mt-4 space-y-2">
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Thousands of brand vouchers and experiences worldwide</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Flexible redemption — digital wallets, gift cards, merchandise</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Multi-currency and multi-country support built in</span>
                    </li>
                  </ul>
                </div>
                <div class="flex items-center justify-center">
                  <img src="/images/features/global-rewards.png" alt="Global reward catalog" class="w-full max-w-sm" />
                </div>
              </div>
            </div>

            <div data-panel="social" class="feature-panel hidden">
              <div class="grid md:grid-cols-[1fr_1fr] gap-6 items-center bg-white rounded-2xl p-6 md:p-8 shadow-sm">
                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-[#0f1f3d]">Drive social recognition</h3>
                  <p class="mt-3 text-sm text-gray-600 leading-relaxed">
                    Appreciate and celebrate the great work and behaviors of your employees and teams on a social feed. Add points and give out e-certificates too!
                  </p>
                  <ul class="mt-4 space-y-2">
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Company-wide social feed for peer-to-peer recognition</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Auto-generated e-certificates and digital awards</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                      <span class="mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-[#E41E3A]/10 flex items-center justify-center"><svg class="w-2.5 h-2.5 text-[#E41E3A]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                      <span class="text-sm text-gray-700">Manager and peer appreciation with point-based rewards</span>
                    </li>
                  </ul>
                </div>
                <div class="flex items-center justify-center">
                  <img src="/images/features/social-recognition.png" alt="Drive social recognition" class="w-full max-w-sm" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Tabs Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.feature-tab');
      const panels = document.querySelectorAll('.feature-panel');

      // Desktop vertical tab classes
      const deskActive = ['border-[#E41E3A]', 'text-[#0f1f3d]', 'font-semibold', 'bg-[#E41E3A]/5'];
      const deskInactive = ['border-transparent', 'text-gray-500', 'font-medium', 'hover:text-[#0f1f3d]', 'hover:bg-gray-50'];

      // Mobile pill tab classes
      const mobActive = ['bg-[#E41E3A]', 'text-white', 'shadow-md'];
      const mobInactive = ['bg-white', 'text-[#0f1f3d]', 'border', 'border-gray-200'];

      function isDesktopTab(el) {
        return el.closest('[role="tablist"]')?.classList.contains('border-l-2') ||
               el.closest('.border-l-2') !== null;
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');

          tabs.forEach((t) => {
            const isActive = t.getAttribute('data-tab') === target;
            t.setAttribute('aria-selected', String(isActive));

            if (isDesktopTab(t)) {
              // Desktop vertical style
              if (isActive) {
                deskInactive.forEach((c) => t.classList.remove(c));
                deskActive.forEach((c) => t.classList.add(c));
              } else {
                deskActive.forEach((c) => t.classList.remove(c));
                deskInactive.forEach((c) => t.classList.add(c));
              }
            } else {
              // Mobile pill style
              if (isActive) {
                mobInactive.forEach((c) => t.classList.remove(c));
                mobActive.forEach((c) => t.classList.add(c));
              } else {
                mobActive.forEach((c) => t.classList.remove(c));
                mobInactive.forEach((c) => t.classList.add(c));
              }
            }
          });

          // Switch panels with fade
          panels.forEach((p) => {
            if (p.getAttribute('data-panel') === target) {
              p.classList.remove('hidden');
              p.style.opacity = '0';
              p.style.transform = 'translateY(8px)';
              requestAnimationFrame(() => {
                p.style.transition = 'opacity 0.3s ease-out, transform 0.3s ease-out';
                p.style.opacity = '1';
                p.style.transform = 'translateY(0)';
              });
            } else {
              p.classList.add('hidden');
              p.style.opacity = '0';
              p.style.transform = 'translateY(8px)';
            }
          });
        });
      });
    });
  </script>

  <!-- Stats Bar -->
  <section class="py-16 bg-white">
    <div
      class="anim-fade-up max-w-5xl mx-auto rounded-3xl py-12 px-8 md:px-16"
      style="background: radial-gradient(ellipse at center, #e8192c 0%, #b01020 100%); box-shadow: 0 8px 40px rgba(180,10,30,0.25);"
    >
      <div class="grid grid-cols-2 gap-8 text-center text-white md:grid-cols-4 md:gap-0 md:divide-x md:divide-white/30">
        <div class="px-4">
          <div class="text-5xl font-extrabold" data-count-to="20" data-count-suffix="+">0</div>
          <div class="mt-3 text-sm uppercase tracking-widest font-medium opacity-90">Years of Experience</div>
        </div>
        <div class="px-4">
          <div class="text-5xl font-extrabold" data-count-to="100" data-count-suffix="+">0</div>
          <div class="mt-3 text-sm uppercase tracking-widest font-medium opacity-90">Clients</div>
        </div>
        <div class="px-4">
          <div class="text-5xl font-extrabold" data-count-to="500" data-count-suffix="K+">0</div>
          <div class="mt-3 text-sm uppercase tracking-widest font-medium opacity-90">Users</div>
        </div>
        <div class="px-4">
          <div class="text-5xl font-extrabold" data-count-to="1.5" data-count-suffix="M+">0</div>
          <div class="mt-3 text-sm uppercase tracking-widest font-medium opacity-90">Annual Awards</div>
        </div>
      </div>
    </div>
  </section>

  <!-- GRG Advantage -->
  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="anim-fade-up text-3xl md:text-4xl font-bold text-center text-[#0f1f3d]">The GRG India Advantage</h2>
      <p class="anim-fade-up mt-3 text-center text-gray-600 max-w-2xl mx-auto text-sm" data-anim-delay="100">
        We give more power to you by simplifying everyday operations and delivering exemplary results.

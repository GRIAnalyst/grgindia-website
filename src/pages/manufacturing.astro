---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Manufacturing Solutions" description="Channel incentive solutions for the manufacturing industry.">
  <section class="bg-gradient-to-br from-teal-600 to-teal-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold">Manufacturing Solutions</h1>
        <p class="mt-6 text-lg md:text-xl text-teal-100">
          Streamline incentive management across your manufacturing supply chain and distribution network.
        </p>
        <a
          href="/book-a-demo"
          class="mt-8 inline-block px-6 py-3 bg-white text-teal-700 font-semibold rounded-lg hover:bg-teal-50"
        >
          Get Started
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center">Why Manufacturers Choose Us</h2>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: 'Distributor Programs', desc: 'Incentivize distributors to hit volume targets and expand market reach.' },
          { title: 'Channel Rebates', desc: 'Automate complex rebate calculations with full transparency and audit trails.' },
          { title: 'Multi-tier Incentives', desc: 'Manage incentive programs across multiple distribution tiers seamlessly.' },
        ].map((item) => (
          <div class="p-6 border border-gray-200 rounded-xl">
            <h3 class="text-lg font-semibold">{item.title}</h3>
            <p class="mt-2 text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

---
const navLinks = [
  {
    label: 'Products',
    children: [
      { label: 'Buzzz', href: '/buzzz-for-employee-motivation' },
      { label: 'My Incentives', href: '/my-incentives-for-sales-motivation' },
    ],
  },
  {
    label: 'Solutions',
    children: [
      { label: 'Retail', href: '/retail' },
      { label: 'Auto', href: '/auto' },
      { label: 'Manufacturing', href: '/manufacturing' },
      { label: 'IT Services', href: '/it-services' },
    ],
  },
  {
    label: 'Resources',
    children: [
      { label: 'Blog', href: '/blog' },
      { label: 'Customer Stories', href: '/customer-stories' },
    ],
  },
  {
    label: 'Company',
    children: [
      { label: 'About', href: '/about-us' },
      { label: 'Careers', href: '/careers' },
    ],
  },
];
---

<!-- Utility Bar -->
<div class="bg-[#E41E3A] text-white text-xs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-end h-8 gap-4">
    <a href="https://clients.letsbuzzz.com/" target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors font-medium">Buzzz Login</a>
    <span class="text-white/40">|</span>
    <a href="https://clients.myincentives.in/" target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors font-medium">My Incentives Login</a>
  </div>
</div>

<!-- Main Nav -->
<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/images/logo.png" alt="GRG India" class="h-10 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <div class="relative group">
            <button
              class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 inline-flex items-center gap-1"
            >
              {link.label}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-1 hidden group-hover:block">
              <div class="bg-white border border-gray-200 rounded-lg shadow-lg py-2 min-w-[180px]">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
        <a href="/contact-us" class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
          Contact Us
        </a>
        <a
          href="/book-a-demo"
          class="ml-2 px-5 py-2 border-2 border-[#E41E3A] text-[#E41E3A] text-sm font-medium rounded-full hover:bg-[#E41E3A] hover:text-white transition-colors"
        >
          Book A Demo
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-gray-700 hover:bg-gray-100"
        aria-label="Open menu"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <div class="mobile-dropdown">
          <button
            class="mobile-dropdown-btn w-full flex items-center justify-between py-2 text-sm font-medium text-gray-700"
          >
            {link.label}
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="mobile-dropdown-content hidden pl-4 pb-2 space-y-1">
            {link.children.map((child) => (
              <a href={child.href} class="block py-1.5 text-sm text-gray-600 hover:text-gray-900">
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ))}
      <a href="/contact-us" class="block py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
        Contact Us
      </a>
      <div class="pt-2 mt-2 border-t border-gray-100 flex gap-3">
        <a href="https://clients.letsbuzzz.com/" target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2 text-sm font-medium text-[#E41E3A] border border-[#E41E3A] rounded-lg hover:bg-red-50">Buzzz Login</a>
        <a href="https://clients.myincentives.in/" target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2 text-sm font-medium text-[#E41E3A] border border-[#E41E3A] rounded-lg hover:bg-red-50">My Incentives</a>
      </div>
      <a
        href="/book-a-demo"
        class="block mt-2 text-center px-5 py-2 bg-[#E41E3A] text-white text-sm font-medium rounded-lg hover:bg-[#c9182f]"
      >
        Book A Demo
      </a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  document.querySelectorAll('.mobile-dropdown-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const arrow = btn.querySelector('svg');
      content?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>
